{
  "manifest_version": 3,
  "name": "Sentinel: Deception Detection",
  "version": "1.0",
  "description": "Real-time detection of Dark Patterns and Phishing attacks.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": [
        "styles/content.css"
      ],
      "js": [
        "utils/helpers.js",
        "utils/hashing.js",
        "services/messaging.js",
        "ui/highlights.js",
        "ui/uiManager.js",
        "scanner/batching.js",
        "scanner/domScanner.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  }
}
